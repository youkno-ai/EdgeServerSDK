# Copy to .env.local and fill values for local publish workflows.
# This file is auto-loaded by scripts/* and Makefile.

# OpenAPI discovery overrides (optional)
# VERSIONS_INDEX_URL=https://belong-openapi.web.app/api/versions.json
# OPENAPI_SPEC_URL_TEMPLATE=https://belong-openapi.web.app/api/<VERSION>/openapi.json

# npm publish
NPM_TOKEN=

# Maven Central publish (Central Portal token user/password)
SONATYPE_USERNAME=
SONATYPE_PASSWORD=

# Signing for Maven publish (choose one approach)
# 1) Inline armored key (single or multi-line supported if quoted correctly)
# SIGNING_KEY=
# 2) Preferred: path to ASCII-armored private key file
SIGNING_KEY_FILE=.secrets/maven-signing-key.asc
SIGNING_PASSWORD=
